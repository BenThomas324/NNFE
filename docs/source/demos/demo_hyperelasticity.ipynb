   "source": [
    "    def get_tensor_map(self):\n",
    "\n",
    "        def psi(F):\n",
    "            \"\"\"Strain energy function for a Neohookean material.\n",
    "\n",
    "            Args:\n",
    "                F (np.array): Deformation gradient tensor. This function will be vmapped over twice\n",
    "                for the cells as well as the quadrature points\n",
    "\n",
    "            Returns:\n",
    "                \\psi (scalar): Returns the value of the strain energy\n",
    "            \"\"\"\n",
    "            E = 10.\n",
    "            nu = 0.3\n",
    "            mu = E / (2. * (1. + nu))\n",
    "            kappa = E / (3. * (1. - 2. * nu))\n",
    "            J = np.linalg.det(F)\n",
    "            Jinv = J**(-2. / 3.)\n",
    "            I1 = np.trace(F.T @ F)\n",
    "            energy = (mu / 2.) * (Jinv * I1 - 3.) + (kappa / 2.) * (J - 1.)**2.\n",
    "            return energy\n",
    "\n",
    "        # Derivative of the strain energy wrt F results in P\n",
    "        P_fn = jax.grad(psi)\n",
    "\n",
    "        def first_PK_stress(u_grad):\n",
    "            \"\"\"The function that maps u_grad to P by constructing F\n",
    "            and evaluating the deriative of psi\n",
    "\n",
    "            Args:\n",
    "                u_grad (np.array): Displacement gradient\n",
    "\n",
    "            Returns:\n",
    "                P (np.array): First Pk stress\n",
    "            \"\"\"\n",
    "            I = np.eye(self.dim)\n",
    "            F = u_grad + I\n",
    "            P = P_fn(F)\n",
    "            return P\n",
    "\n",
    "        return first_PK_stress"
   ]
  },
